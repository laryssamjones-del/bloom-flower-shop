{
  "name": "stay-awhile-jam-kit",
  "version": "0.1.0",
  "description": "Bare-bones starter for the Stay Awhile cozy game jam on Run.Game. A blank scaffold with the Rundot SDK plumbing pre-wired (saving, time, gentle notifications, purchases, sharing) and agent docs that point at the SDK surfaces worth reaching for in a cozy game. No mechanics, no sample game — bring your own idea.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "_build": "tsc && vite build",
    "build": "npm run _build",
    "build:bundled": "cross-env RUNDOT_GAME_DISABLE_EMBEDDED_LIBS=true npm run _build",
    "preview": "vite preview",
    "deploy": "npm run build && rundot deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --write",
    "format:check": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --check"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "RUN.game",
    "cozy-game",
    "starter-kit",
    "game-jam"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "firebase": "^12.12.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@series-inc/rundot-game-sdk": "^5.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@series-inc/rundot-game-sdk"
    ]
  }
}
